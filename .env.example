# Environment variables for vLLM manager
# Copy from .env.example and fill in your values

# Default model name (used when no model is specified on the command line)
MODEL=

# Project directory (absolute path to this repo)
PROJECT_DIR=/absolute/path/to/vllm-starter

# HuggingFace auth token
HF_TOKEN=hf_your_token_here

# vLLM API key for authenticated requests
VLLM_API_KEY=sk-vllm-default-key

# Default model name (used when no model is specified on the command line)
MODEL=

# Loki log forwarding
#LOKI_URL=http://192.168.88.10:3100
#SERVICE_NAME=vllm

# Enable dry run mode (skip actual docker commands)
# Uncomment when running on the same machine where vLLM is running (local execution)
# DRY_RUN=true

# ── SSH remote execution ─────────────────────────────────────────────────
# When DRY_RUN is NOT set, commands run remotely via SSH by default.
# Copy this section to .env and fill in your values.

SSH_USER=admin
SSH_HOST=192.168.88.57
SSH_PORT=22
SSH_KEY=~/.ssh/id_ed25519
SSH_DIR=/home/administrator/vllm-starters

# Set to 0 on remote hosts to disable SSH recursion (remote runs locally)
# VLLM_REMOTE=0
